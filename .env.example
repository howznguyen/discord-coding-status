# Optional environment overrides for local development.
# Normal setup writes compact JSON to ~/discord-coding-status/config.json.

DISCORD_CODING_STATUS_DETAIL_LEVEL=project
DISCORD_CODING_STATUS_CODEX_QUOTA_SOURCE=oauth
# DISCORD_CODING_STATUS_ACTIVITY_STYLE=fun

# Fine-grained display layout. Omit these to follow the selected detail-level preset.
# DISCORD_CODING_STATUS_SHOW_ACTIVITY=true
# DISCORD_CODING_STATUS_SHOW_PROJECT=true
# DISCORD_CODING_STATUS_SHOW_MODEL=true
# DISCORD_CODING_STATUS_SHOW_QUOTA=true
# DISCORD_CODING_STATUS_SHOW_CONTEXT=false
# DISCORD_CODING_STATUS_SHOW_PACKAGE=false

# Advanced runtime controls. Polling is a fallback; hook state changes are also watched immediately.
# DISCORD_CODING_STATUS_POLL_INTERVAL_MS=10000
# DISCORD_CODING_STATUS_PROCESS_DETECTION=on
# CLAUDE_CONFIG_DIR=~/.claude
# DISCORD_CODING_STATUS_CLAUDE_KEYCHAIN=on

# Only set these when you want to override the built-in defaults.
# DISCORD_CODING_STATUS_PLAN_TEXT=Pro
# DISCORD_CODING_STATUS_LIMITS_TEXT=5h 100% • 7d 100%
# DISCORD_CODING_STATUS_STATE_FILE=~/discord-coding-status/states.json
